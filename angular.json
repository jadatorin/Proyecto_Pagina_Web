{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "Proyecto_Pagina_Web": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/Proyecto_Pagina_Web",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "optimization": true,
              "extractLicenses": true,
              "sourceMap": false
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "host": "0.0.0.0",
            "port": 4200
          },
          "configurations": {
            "production": {
              "buildTarget": "Proyecto_Pagina_Web:build:production"
            },
            "development": {
              "buildTarget": "Proyecto_Pagina_Web:build:development"
            }
          },
          "defaultConfiguration": "development"
        },   
        "server": {
          "builder": "@angular-devkit/build-angular:server",
          "options": {
            "outputPath": "dist/Proyecto_Pagina_Web/server",
            "main": "server.ts",
            "tsConfig": "tsconfig.server.json"
          },
          "configurations": {
            "production": {
              "outputHashing": "media"
            },
            "development": {
              "optimization": false
            }
          }
        },
        "serve-ssr": {
          "builder": "@angular/ssr:dev-server",
          "configurations": {
            "development": {
              "browserTarget": "Proyecto_Pagina_Web:build:development",
              "serverTarget": "Proyecto_Pagina_Web:server:development"
            },
            "production": {
              "browserTarget": "Proyecto_Pagina_Web:build:production",
              "serverTarget": "Proyecto_Pagina_Web:server:production"
            }
          },
          "defaultConfiguration": "development"
        },
        "prerender": {
          "builder": "@angular/ssr:prerender",
          "options": {
            "routes": ["/", "/home", "/about"]
          },
          "configurations": {
            "production": {
              "browserTarget": "Proyecto_Pagina_Web:build:production",
              "serverTarget": "Proyecto_Pagina_Web:server:production"
            },
            "development": {
              "browserTarget": "Proyecto_Pagina_Web:build:development",
              "serverTarget": "Proyecto_Pagina_Web:server:development"
            }
          },
          "defaultConfiguration": "production"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.scss"
            ],
            "codeCoverage": true
          }
        }
      }
    }
  }
}